{
  "name": "islas-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "check": "turbo lint && turbo build",
    "agent": "bun --cwd apps/agent start",
    "web": "bun --cwd apps/web dev"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1",
    "turbo": "^2.0.0"
  },
  "packageManager": "bun@1.1.0"
}