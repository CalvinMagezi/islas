# ── Domain ────────────────────────────────────────────────────────────────────
# The base domain for all services. Subdomains are auto-configured:
#   yourdomain.com        → web app
#   api.yourdomain.com    → Convex WebSocket/HTTP
#   actions.yourdomain.com → Convex HTTP actions / MCP gateway
#   dash.yourdomain.com   → Convex admin dashboard
DOMAIN=yourdomain.com

# ── Tenant Configuration ──────────────────────────────────────────────────────
# Which config profile to load (default, oakstone)
TENANT_CONFIG=oakstone

# ── Convex Self-Hosted ────────────────────────────────────────────────────────
# Generated by setup.sh via: docker compose exec convex ./generate_admin_key.sh
CONVEX_ADMIN_KEY=

# ── App Credentials ───────────────────────────────────────────────────────────
# Strong passphrase for single-user auth (minimum 32 characters)
ACCESS_PASSPHRASE=your-strong-passphrase-32-chars-minimum

# ── Web Push (VAPID) ─────────────────────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ── Agent Config ──────────────────────────────────────────────────────────────
# Single API key for ALL AI operations: LLM calls + embeddings (openai/text-embedding-3-small)
# No separate OPENAI_API_KEY required — OpenRouter handles both.
OPENROUTER_API_KEY=
# API key for Convex HTTP actions (must match ISLAS_API_KEY set in Convex env)
ISLAS_API_KEY=local-master-key
# Secret for agent worker authentication: openssl rand -hex 32
WORKER_SECRET=
# Default LLM model via OpenRouter
DEFAULT_MODEL=moonshotai/kimi-k2.5
# Token for MCP gateway authentication
MCP_GATEWAY_TOKEN=

# ── Caddy Dashboard Auth ──────────────────────────────────────────────────────
DASHBOARD_USER=admin
# Generate with: docker run --rm caddy:2-alpine caddy hash-password --plaintext yourpassword
DASHBOARD_PASSWORD_HASH=
