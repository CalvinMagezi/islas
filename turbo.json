{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
        "build": {
            "dependsOn": [
                "^build"
            ],
            "outputs": [
                ".next/**",
                "dist/**",
                "convex/_generated/**"
            ],
            "env": [
                "CONVEX_DEPLOYMENT",
                "CONVEX_DEPLOY_KEY",
                "NEXT_PUBLIC_CONVEX_URL",
                "NEXT_PUBLIC_CONVEX_SITE_URL",
                "NEXT_PUBLIC_VAPID_PUBLIC_KEY",
                "NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY",
                "OPENROUTER_API_KEY",
                "BRAVE_SEARCH_API_KEY",
                "DEFAULT_MODEL"
            ]
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        "lint": {
            "cache": true
        }
    }
}